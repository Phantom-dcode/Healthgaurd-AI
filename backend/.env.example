# ============================================================
#  HealthGuard AI — Environment Configuration
#  INSTRUCTIONS: Copy this file to .env and fill in values
#  NEVER commit .env to version control
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="HealthGuard AI"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=development             # development | staging | production

# ── Database ─────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://healthguard_user:yourpassword@localhost:5432/healthguard_db

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AWS (Phase 8 - Cloud Deployment) ─────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=healthguard-reports

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
